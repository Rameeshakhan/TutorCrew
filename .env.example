# ════════════════════════════════════════════════════════════════
#  TutorCrew — Environment Variables
#  Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────
# Choose your LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Auth (single demo user) ───────────────────────────────────────
DEMO_USERNAME=ahmed
DEMO_PASSWORD=tutorcrew123
DEMO_NAME=Ahmed Khan
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRE_HOURS=24

# ── ChromaDB ──────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_data

# ── CORS (comma-separated) ────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Optional: Google Calendar (MCP Server) ────────────────────────
# Download OAuth credentials from Google Cloud Console
# → APIs & Services → Credentials → OAuth 2.0 Client ID → Desktop app
GOOGLE_CREDENTIALS_PATH=./google_credentials.json
GOOGLE_CALENDAR_ID=primary

# ── Optional: Twilio WhatsApp (MCP Server) ────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Optional: LangSmith tracing ───────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=TutorCrew
